# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase public client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server/admin + Postgres
# Use the full Supabase host, not just postgres.<project-ref>.
# Direct example: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require
# Pooler example: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Corsair integrations
# Prefer the App SDK/dev-key naming used in Corsair docs. CORSAIR_API_KEY remains supported as a fallback.
CORSAIR_DEV_KEY=
# Optional. If left empty, the app will list/create an instance by CORSAIR_INSTANCE_NAME.
# If this is accidentally set to "triageos", the app treats it as a name fallback.
# If you do set it, use the real instance ID from Corsair, not the display name.
CORSAIR_INSTANCE_ID=
# Used only when CORSAIR_INSTANCE_ID is empty. Must not contain spaces.
CORSAIR_INSTANCE_NAME=triageos
CORSAIR_API_BASE_URL=https://api.corsair.dev
# auto tries the official SDK first when installed, then falls back to REST.
CORSAIR_DRIVER=auto
CORSAIR_API_KEY=
CORSAIR_CLIENT_ID=
CORSAIR_CLIENT_SECRET=
CORSAIR_WEBHOOK_SECRET=

# Google OAuth credentials used by npm run corsair:google-oauth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Comma-separated emails that should become admin on sign-in
ADMIN_EMAILS=
